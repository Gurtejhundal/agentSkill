{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Workflow Schema",
  "type": "object",
  "required": [
    "name",
    "description",
    "steps"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  }
}
