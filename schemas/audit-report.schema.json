{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Website Audit Report",
  "type": "object",
  "required": [
    "site",
    "findings",
    "priorities",
    "tests",
    "limitations"
  ],
  "properties": {
    "site": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "priorities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
