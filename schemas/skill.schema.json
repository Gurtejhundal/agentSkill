{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Skill Manifest",
  "type": "object",
  "required": [
    "name",
    "description",
    "version",
    "tags"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "version": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  }
}
